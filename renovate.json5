{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],
  minimumReleaseAge: "7 days",
  lockFileMaintenance: {
    enabled: true,
  },
  labels: ["dependencies"],
  packageRules: [
    {
      matchCategories: ["ci"],
      addLabels: ["ci"],
    },
    {
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      addLabels: ["dev dependencies"],
      automerge: true,
    },
    {
      matchManagers: ["cargo"],
      addLabels: ["rust"],
    },
  ],
}
